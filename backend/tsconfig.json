{
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "lib": ["ESNext"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "skipLibCheck": true,
    "strict": true,
    "useUnknownInCatchVariables": false,
    "noImplicitAny": false,
    "target": "ES2022",
    "typeRoots": ["node_modules/@types", "src/lib"],
    "paths": {
      "src/*": ["./src/*"]
    }
  },
  "include": ["src/**/*.ts", "knexfile.ts"], //Manually adding knexfile.ts to be included
  "exclude": ["node_modules", "dist"]
}
